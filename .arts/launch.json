{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: 运行模块",
            "type": "debugpy",
            "request": "launch",
            "module": "前端.入口.main",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "--tb=short"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest: 当前目录",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${fileDirname}",
                "-v",
                "--tb=short",
                "--cov=前端",
                "--cov-report=term"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest: 全部测试",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "测试",
                "-v",
                "--tb=short",
                "--cov=前端",
                "--cov-report=html:测试/报告/htmlcov",
                "--html=测试/报告/report.html"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest: 单元测试",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "测试/单元测试",
                "-v",
                "-m",
                "unit",
                "--tb=short"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest: 集成测试",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "测试/集成测试",
                "-v",
                "-m",
                "integration",
                "--tb=short"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}