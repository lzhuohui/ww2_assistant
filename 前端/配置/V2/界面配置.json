{
  "说明": "界面配置文件 - 唯一维护文件，包含卡片信息、控件列表、标签、选项、默认值、开关状态",
  "版本": "3.0",
  "使用说明": {
    "本文件是唯一需要用户维护的配置文件": true,
    "可修改项": [
      "label - 显示标签，可随意修改",
      "options - 选项列表，可增删改",
      "default - 默认值，可修改",
      "enabled - 默认开关状态，可修改",
      "subtitle - 卡片副标题，可修改"
    ],
    "不建议修改项": [
      "id - 控件标识符，修改会导致配置丢失",
      "type - 控件类型，修改可能导致界面异常",
      "section - 配置节名称，修改会导致配置丢失"
    ],
    "注意事项": [
      "JSON格式要求：最后一项不能有逗号",
      "字符串必须用双引号",
      "可以分行写，不影响程序读取"
    ]
  },
